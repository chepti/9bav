# העתיקו קובץ זה ל-.env.local ומלאו את הערכים.
# בלי הערכים האלה האתר רץ במצב מקומי (localStorage) — כלומר לא חי ולא משותף.

# --- Firebase (מ-Project settings > General > Your apps > SDK setup) ---
VITE_FB_API_KEY=
VITE_FB_AUTH_DOMAIN=
VITE_FB_PROJECT_ID=
VITE_FB_STORAGE_BUCKET=
VITE_FB_SENDER_ID=
VITE_FB_APP_ID=

# האימייל שיקבל אוטומטית הרשאת מודרטור (בעל/ת האתר)
VITE_OWNER_EMAIL=chepti@gmail.com

# --- Google Drive upload (Apps Script Web App URL) ---
# כתובת ה-Web App שתפרסמו לפי docs/apps-script-drive.gs
VITE_DRIVE_ENDPOINT=
