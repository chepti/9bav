rules_version = '2';

// Firestore security rules for the Gush Katif documentation project.
//
// Model note: settlements are stored as single documents with POIs/media
// embedded. These rules keep reads public and restrict writes to signed-in
// users (community-wiki style). For stronger moderation guarantees (e.g. only
// moderators can flip a media item to "approved"), migrate media to a
// subcollection and add field-level checks — see SETUP.md.

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // CHANGE this to the site owner's email (also set VITE_OWNER_EMAIL).
    function ownerEmail() {
      return 'chepti@gmail.com';
    }
    function isOwner() {
      return signedIn() && request.auth.token.email == ownerEmail();
    }
    function isModerator() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'moderator';
    }
    // The role a signed-in user is entitled to: owner => moderator; otherwise
    // whatever the owner assigned to their email in `roles/{email}`, else resident.
    function assignedRole() {
      return isOwner()
        ? 'moderator'
        : (exists(/databases/$(database)/documents/roles/$(request.auth.token.email))
            ? get(/databases/$(database)/documents/roles/$(request.auth.token.email)).data.role
            : 'resident');
    }

    // Settlement documents (with embedded POIs + media)
    match /settlements/{settlementId} {
      allow read: if true;                 // public site
      allow create, update: if signedIn(); // residents & moderators may contribute
      allow delete: if isModerator();
    }

    // User profiles. A user's role must equal what they're entitled to
    // (assignedRole()), so nobody can self-promote; the owner grants moderator
    // rights by adding the person's email to /roles (see below).
    match /users/{uid} {
      allow read: if signedIn();
      allow create: if signedIn() && request.auth.uid == uid
        && request.resource.data.role == assignedRole();
      allow update: if (signedIn() && request.auth.uid == uid
                        && request.resource.data.role == assignedRole())
                    || isOwner() || isModerator();
    }

    // Role assignments by email. Public site users never touch this; only the
    // owner and moderators manage it (this is the front-end "add moderator" UI).
    match /roles/{email} {
      allow read: if signedIn();
      allow write: if isOwner() || isModerator();
    }

    // Public visitor counter (meta/stats.visits). Anyone may read; a write may
    // only create the counter or bump `visits` by exactly one — so it can't be
    // reset or inflated arbitrarily.
    match /meta/{docId} {
      allow read: if true;
      allow create: if request.resource.data.visits is int;
      allow update: if request.resource.data.visits == resource.data.visits + 1;
    }
  }
}
